  "components": {
    "schemas": {
      "CreateCarDto": {
        "required": [
          "brand",
          "fuelType",
          "model"
        ],
        "type": "object",
        "properties": {
          "brand": {
            "minLength": 1,
            "type": "string"
          },
          "model": {
            "minLength": 1,
            "type": "string"
          },
          "year": {
            "maximum": 2100,
            "minimum": 1900,
            "type": "integer",
            "format": "int32"
          },
          "price": {
            "maximum": 1.7976931348623157E+308,
            "minimum": 0,
            "type": "number",
            "format": "double"
          },
          "fuelType": {
            "minLength": 1,
            "type": "string"
          },
          "clientId": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "CreateClaimDto": {
        "required": [
          "description",
          "policyId",
          "userId"
        ],
        "type": "object",
        "properties": {
          "description": {
            "minLength": 1,
            "type": "string"
          },
